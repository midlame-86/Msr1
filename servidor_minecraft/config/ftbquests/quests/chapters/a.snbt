			}]
			x: -0.5d
			y: 5.0d
		}
		{
			dependencies: ["618B9DCA100813DB"]
			description: [
				"&c&oTercer guardian el antiguo. Un paladin poderoso que tenia su propio asentamiento pero un dia sobre el y toda la gente que vivia en el asentamiento cayo una maldicion perdiendo poco a poco su humanidad naciendo nuevo dientes y picos rocos por todas partes. Actualmente lo unico que queda de su humanidad es su arma un ancla que usaba como martillo"
				"&cNivel de dificultad: ☠☠☠"
			]
			id: "026D6F6EBFC5E4A9"
			shape: "square"
			subtitle: "Guardian antiguo"
			tasks: [{
				advancement: "legendary_monsters:defeat_the_ancient_guardian"
